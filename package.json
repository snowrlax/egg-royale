{
  "name": "fish-jam",
  "private": true,
  "workspaces": [
    "packages/*",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w packages/shared && npm run build -w server && npm run build -w client",
    "build:shared": "npm run build -w packages/shared"
  }
}
